#!/bin/bash
set -u

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
PKG_HOME="${TRIM_PKGHOME:-$(CDPATH= cd -- "${SCRIPT_DIR}/.." && pwd)}"
PKG_VAR="${TRIM_PKGVAR:-${PKG_HOME}/var}"
APP_BIN="${PKG_HOME}/app/server/aicore-web"
LOG_FILE="${PKG_VAR}/aicore-web.log"
PID_FILE="${PKG_VAR}/aicore-web.pid"
HOST="${AICORE_WEB_HOST:-0.0.0.0}"
PORT="${AICORE_WEB_PORT:-8731}"

log_msg() {
    mkdir -p "${PKG_VAR}"
    echo "$(date '+%Y-%m-%d %H:%M:%S') - $1" >> "${LOG_FILE}"
}

check_process() {
    local pid="$1"
    kill -0 "${pid}" 2>/dev/null
}

status_process() {
    if [ -f "${PID_FILE}" ]; then
        local pid
        pid=$(head -n 1 "${PID_FILE}" | tr -d '[:space:]')
        if [ -n "${pid}" ] && check_process "${pid}"; then
            return 0
        fi
        rm -f "${PID_FILE}"
    fi
    return 3
}

start_process() {
    if status_process; then
        log_msg "AICore Web 已在运行。"
        return 0
    fi

    if [ ! -x "${APP_BIN}" ]; then
        log_msg "未找到可执行文件：${APP_BIN}"
        return 1
    fi

    log_msg "启动 AICore Web：${HOST}:${PORT}"
    "${APP_BIN}" --host "${HOST}" --port "${PORT}" >> "${LOG_FILE}" 2>&1 &
    printf "%s" "$!" > "${PID_FILE}"
    return 0
}

stop_process() {
    log_msg "停止 AICore Web。"
    if [ ! -f "${PID_FILE}" ]; then
        return 0
    fi

    local pid
    pid=$(head -n 1 "${PID_FILE}" | tr -d '[:space:]')
    if [ -z "${pid}" ] || ! check_process "${pid}"; then
        rm -f "${PID_FILE}"
        return 0
    fi

    kill -TERM "${pid}" >> "${LOG_FILE}" 2>&1 || true
    local count=0
    while check_process "${pid}" && [ "${count}" -lt 10 ]; do
        sleep 1
        count=$((count + 1))
    done

    if check_process "${pid}"; then
        kill -KILL "${pid}" >> "${LOG_FILE}" 2>&1 || true
    fi
    rm -f "${PID_FILE}"
    return 0
}

case "${1:-}" in
start)
    start_process
    ;;
stop)
    stop_process
    ;;
status)
    status_process
    ;;
*)
    exit 1
    ;;
esac
